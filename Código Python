def validar_entrada_clinica(nombre, dni, edad, musculo, grasa):
    if not nombre or not dni or not edad:
        raise ValueError("Nombre, DNI/NIE y Edad son obligatorios.")
 
    try:
        edad_int = int(edad)
    except ValueError:
        raise ValueError("La edad debe ser un número entero.")
 
    if edad_int < 1 or edad_int > 120:
        raise ValueError("La edad introducida está fuera de un rango razonable.")
 
    if musculo <= 0:
        raise ValueError("La profundidad tumoral debe ser mayor que 0 mm.")
 
    if grasa < 0:
        raise ValueError("El espesor de grasa no puede ser negativo.")
 
    if musculo > 100:
        raise ValueError("La profundidad tumoral introducida es excesiva para este modelo.")
 
    if grasa > 50:
        raise ValueError("El espesor de grasa introducido es excesivo para este modelo.")
 
    return edad_int
 
 
def evaluar_rango_experiencia(musculo, grasa):
    rangos = obtener_rangos_experiencia()
 
    dentro_mus = rangos["mus_min"] <= musculo <= rangos["mus_max"]
    dentro_gra = rangos["gra_min"] <= grasa <= rangos["gra_max"]
 
    if dentro_mus and dentro_gra:
        return "Sí", ""
    elif dentro_mus or dentro_gra:
        return "Parcial", "El caso se sitúa parcialmente fuera del rango cubierto por la base de experiencia."
    else:
        return "No", "El caso se encuentra fuera del rango principal de experiencia. Interpretar con precaución."
 
 
def determinar_simulacion_pendiente(rango_cubierto, confianza):
    if rango_cubierto == "No":
        return "Sí"
    if rango_cubierto == "Parcial" and confianza == "Baja":
        return "Sí"
    if confianza == "Baja":
        return "Sí"
    return "No"
 
 
def exportar_historial_csv():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("""
SELECT fecha, nombre, dni, edad, sexo, musculo, grasa, k_usado, tipo_caso,
l_slot, potencia, temp_max, dist_knn, similitud, seguridad,
confianza, rango_cubierto, simulacion_pendiente
FROM Historial_v6
ORDER BY id DESC
""")
    filas = cur.fetchall()
    conn.close()
 
    if not filas:
        messagebox.showwarning("Aviso", "No hay registros en el historial para exportar.")
        return
 
    nombre_sugerido = f"Historial_HYPERSAD_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
 
    ruta = filedialog.asksaveasfilename(
        defaultextension=".csv",
        filetypes=[("Archivo CSV", "*.csv")],
        initialfile=nombre_sugerido,
        title="Guardar historial como CSV"
    )
 
    if not ruta:
        return
 
    cabeceras = [
        "Fecha", "Nombre", "DNI/NIE", "Edad", "Sexo", "Musculo_mm", "Grasa_mm",
        "k_usado", "Tipo_caso", "L_slot_mm", "Potencia_W", "Temp_max_C",
        "Dist_knn", "Similitud_%", "Seguridad", "Confianza",
        "Rango_cubierto", "Simulacion_pendiente"
    ]
 
    try:
        with open(ruta, "w", newline="", encoding="utf-8-sig") as f:
            writer = csv.writer(f, delimiter=";")
            writer.writerow(cabeceras)
            writer.writerows(filas)
 
        messagebox.showinfo("Éxito", f"Historial exportado correctamente a:\n{ruta}")
    except Exception as e:
        messagebox.showerror("Error", f"No se pudo exportar el historial.\n\nDetalle: {e}")
 
 
