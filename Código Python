def ver_grafico_knn_canvas(root, p_mus, p_grasa, vecinos):
    experiencia = leer_experiencia()
 
    win = tk.Toplevel(root)
    win.title(f"Plano Músculo–Grasa (kNN - {len(vecinos)} Vecinos)")
    win.geometry("1080x760")
    win.configure(bg="white")
 
    canvas = tk.Canvas(win, bg="white", highlightthickness=0)
    canvas.pack(fill="both", expand=True)
 
    W, H = 1020, 700
    L, R, T, B = 85, 360, 60, 95
 
    xs = [c[0] for c in experiencia] + [p_mus]
    ys = [c[1] for c in experiencia] + [p_grasa]
 
    xmin, xmax = min(xs), max(xs)
    ymin, ymax = min(ys), max(ys)
 
    def pad(a, b):
        if math.isclose(a, b):
            a -= 1
            b += 1
        margen = 0.12 * (b - a)
        return a - margen, b + margen
 
    xmin, xmax = pad(xmin, xmax)
    ymin, ymax = pad(ymin, ymax)
 
    plot_w = W - (L + R)
    plot_h = H - (T + B)
 
    def x_to_px(x):
        return L + (x - xmin) / (xmax - xmin) * plot_w
 
    def y_to_px(y):
        return T + (ymax - y) / (ymax - ymin) * plot_h
 
    def color_por_lslot(lslot):
        if lslot <= 82.5:
            return "#1565c0"
        elif lslot <= 85.0:
            return "#1e88e5"
        else:
            return "#42a5f5"
 
    def dibujar_texto_con_fondo(
        x, y, texto,
        fill_text="#263238",
        fill_box="white",
        outline="#cfd8dc",
        font=("Segoe UI", 9),
        anchor="w",
        padx=5,
        pady=3
    ):
        txt = canvas.create_text(
            x, y, text=texto, anchor=anchor, font=font, fill=fill_text
        )
        bbox = canvas.bbox(txt)
        if bbox:
            rect = canvas.create_rectangle(
                bbox[0] - padx, bbox[1] - pady,
                bbox[2] + padx, bbox[3] + pady,
                fill=fill_box, outline=outline
            )
            canvas.tag_lower(rect, txt)
        return txt
 
    canvas.create_text(
        W / 2 - 60, 28,
        text=f"Búsqueda kNN (k={len(vecinos)}) en el plano anatómico",
        font=("Segoe UI", 16, "bold"),
        fill="#0d47a1"
    )
 
    canvas.create_line(L, H - B, W - R, H - B, width=2, fill="#0d47a1")
    canvas.create_line(L, T, L, H - B, width=2, fill="#0d47a1")
 
    DIV = 5
    for i in range(DIV + 1):
        xv = xmin + i * (xmax - xmin) / DIV
        px = x_to_px(xv)
 
        canvas.create_line(px, H - B, px, H - B + 8, fill="#0d47a1")
        canvas.create_text(px, H - B + 22, text=f"{xv:.1f}", font=("Segoe UI", 9))
        canvas.create_line(px, T, px, H - B, fill="#eceff1")
 
        yv = ymin + i * (ymax - ymin) / DIV
        py = y_to_px(yv)
 
        canvas.create_line(L - 8, py, L, py, fill="#0d47a1")
        canvas.create_text(L - 30, py, text=f"{yv:.1f}", font=("Segoe UI", 9))
        canvas.create_line(L, py, W - R, py, fill="#eceff1")
 
    canvas.create_text(
        L + plot_w / 2,
        H - 45,
        text="Profundidad en músculo (mm)",
        font=("Segoe UI", 11, "bold"),
        fill="#0d47a1"
    )
 
    canvas.create_text(
        35,
        T + plot_h / 2,
        text="Espesor de grasa (mm)",
        angle=90,
        font=("Segoe UI", 11, "bold"),
        fill="#0d47a1"
    )
 
    for c in experiencia:
        cx, cy = x_to_px(c[0]), y_to_px(c[1])
        canvas.create_oval(
            cx - 5, cy - 5, cx + 5, cy + 5,
            fill=color_por_lslot(c[2]),
            outline=""
        )
 
    px, py = x_to_px(p_mus), y_to_px(p_grasa)
 
    canvas.create_oval(
        px - 9, py - 9, px + 9, py + 9,
        outline="#d32f2f", width=3
    )
 
    dibujar_texto_con_fondo(
        px + 10, py + 18,
        f"Paciente: M={p_mus:.1f} G={p_grasa:.1f}",
        fill_text="#d32f2f",
        outline="#ef9a9a",
        font=("Segoe UI", 9, "bold"),
        anchor="w"
    )
 
    offsets = [
        (-24, -18),
        (18, -18),
        (18, 18),
        (-24, 18),
        (18, 36)
    ]
 
    for i, (dist, caso) in enumerate(vecinos):
        bx, by = x_to_px(caso[0]), y_to_px(caso[1])
 
        canvas.create_line(
            px, py, bx, by,
            dash=(4, 4),
            fill="#90a4ae",
            width=2
        )
 
        canvas.create_oval(
            bx - 7, by - 7, bx + 7, by + 7,
            fill="#0d47a1",
            outline="white",
            width=1
        )
 
        dx, dy = offsets[i % len(offsets)]
 
        dibujar_texto_con_fondo(
            bx + dx, by + dy,
            f"V{i+1}",
            fill_text="#263238",
            outline="#b0bec5",
            font=("Segoe UI", 9, "bold"),
            anchor="center"
        )
 
    # Leyenda
    lx = W - 285
    ly = 70
 
    dibujar_texto_con_fondo(
        lx, ly,
        "Leyenda L_slot",
        fill_text="#0d47a1",
        outline="#90caf9",
        font=("Segoe UI", 10, "bold"),
        anchor="w"
    )
 
    canvas.create_oval(lx + 8, ly + 28, lx + 16, ly + 36, fill="#1565c0", outline="")
    canvas.create_text(lx + 24, ly + 32, text="L ≤ 82.5 mm", anchor="w", font=("Segoe UI", 9))
 
