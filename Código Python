    def dibujar_antena(self, l_slot):
        self.canvas_antena.delete("all")
 
        self.canvas_antena.create_rectangle(
            15, 10, 85, 165,
            fill="#e3f2fd",
            outline="#64b5f6",
            width=2
        )
 
        l_min = 80.0
        l_max = 90.0
        l_ajustada = max(l_min, min(l_slot, l_max))
 
        h_pixel = 40 + ((l_ajustada - l_min) / (l_max - l_min)) * 80
        y_ini = 10 + (155 - h_pixel) / 2
 
        self.canvas_antena.create_rectangle(
            45, y_ini, 55, y_ini + h_pixel,
            fill="#1976d2",
            outline=""
        )
 
        self.canvas_antena.create_text(
            50, 177,
            text="Ranura adaptable",
            font=("Segoe UI", 8, "bold"),
            fill="#0d47a1"
        )
 
    def dibujar_mapa_termico(self, grasa, musculo, temp):
        self.canvas_calor.delete("all")
 
        H_TOTAL = 155
        prof_max = 50.0
 
        h_grasa = max(15, min(H_TOTAL * (grasa / prof_max), 55))
 
        self.canvas_calor.create_rectangle(
            10, 10, 90, 10 + h_grasa,
            fill="#fff59d",
            outline=""
        )
        self.canvas_calor.create_text(
            50, 10 + h_grasa / 2,
            text="Grasa",
            font=("Segoe UI", 7),
            fill="#827717"
        )
 
        self.canvas_calor.create_rectangle(
            10, 10 + h_grasa, 90, 165,
            fill="#ffcdd2",
            outline=""
        )
        self.canvas_calor.create_text(
            50, 145,
            text="Músculo",
            font=("Segoe UI", 7),
            fill="#c62828"
        )
 
        y_tumor = 10 + h_grasa + (H_TOTAL - h_grasa) * (musculo / 40.0)
        y_tumor = min(y_tumor, 155)
 
        if temp > 44.5:
            color_hot = "#8e0000"
        elif temp > 43.0:
            color_hot = "#e53935"
        elif temp > 41.5:
            color_hot = "#fb8c00"
        else:
            color_hot = "#43a047"
 
        self.canvas_calor.create_oval(
            28, y_tumor - 20, 72, y_tumor + 20,
            fill="",
            outline=color_hot,
            width=2
        )
        self.canvas_calor.create_oval(
            32, y_tumor - 15, 68, y_tumor + 15,
            fill=color_hot,
            outline=""
        )
        self.canvas_calor.create_text(
            50, y_tumor,
            text=f"{temp}º",
            font=("Segoe UI", 8, "bold"),
            fill="white"
        )
 
        self.canvas_calor.create_text(
            50, 177,
            text="Tejidos",
            font=("Segoe UI", 8, "bold"),
            fill="#c62828"
        )
 
