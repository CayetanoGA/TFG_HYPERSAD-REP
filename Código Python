def asegurar_columnas_historial(cursor):
    cursor.execute("PRAGMA table_info(Historial_v6)")
    columnas_actuales = [fila[1] for fila in cursor.fetchall()]
 
    columnas_necesarias = {
        "confianza": "TEXT",
        "rango_cubierto": "TEXT",
        "simulacion_pendiente": "TEXT"
    }
 
    for columna, tipo in columnas_necesarias.items():
        if columna not in columnas_actuales:
            cursor.execute(f"ALTER TABLE Historial_v6 ADD COLUMN {columna} {tipo}")
 
 
