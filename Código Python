def validar_dni_nie(documento):
    documento = documento.upper().replace("-", "").replace(" ", "").strip()
 
    if not re.match(r'^[XYZ]?\d{1,8}[A-Z]$', documento):
        return False
 
    letras = "TRWAGMYFPDXBNJZSQVHLCKE"
 
    if documento[0] in ['X', 'Y', 'Z']:
        mapa_nie = {'X': '0', 'Y': '1', 'Z': '2'}
        numero = mapa_nie[documento[0]] + documento[1:-1]
    else:
        numero = documento[:-1]
 
    try:
        return letras[int(numero) % 23] == documento[-1]
    except ValueError:
        return False
 
 
def leer_experiencia():
    conn = sqlite3.connect(DB_NAME)
    cur = conn.cursor()
    cur.execute("""
SELECT prof_musculo_mm, espesor_grasa_mm, L_slot_mm, potencia_w, temp_max_c
FROM Simulaciones
""")
    datos = cur.fetchall()
    conn.close()
    return datos
 
 
def obtener_rangos_experiencia():
    experiencia = leer_experiencia()
    musculos = [c[0] for c in experiencia]
    grasas = [c[1] for c in experiencia]
    return {
        "mus_min": min(musculos),
        "mus_max": max(musculos),
        "gra_min": min(grasas),
        "gra_max": max(grasas)
    }
 
 
def motor_inferencia(prof_p, grasa_p, k=1):
    experiencia = leer_experiencia()
 
    distancias = [
        (math.sqrt((prof_p - c[0]) ** 2 + (grasa_p - c[1]) ** 2), c)
        for c in experiencia
    ]
    distancias.sort(key=lambda x: x[0])
 
    k_real = min(k, len(distancias))
    vecinos = distancias[:k_real]
 
    if k_real == 1:
        return vecinos[0][1], vecinos[0][0], vecinos
 
    eps = 1e-6
    pesos = [1 / (d ** 2 + eps) for d, c in vecinos]
    suma_pesos = sum(pesos)
 
    avg_lslot = sum(w * c[2] for w, (d, c) in zip(pesos, vecinos)) / suma_pesos
    avg_pot = sum(w * c[3] for w, (d, c) in zip(pesos, vecinos)) / suma_pesos
    avg_temp = sum(w * c[4] for w, (d, c) in zip(pesos, vecinos)) / suma_pesos
    avg_dist = sum(d for d, c in vecinos) / k_real
 
    caso_consenso = (
        prof_p,
        grasa_p,
        round(avg_lslot, 1),
        round(avg_pot, 1),
        round(avg_temp, 1)
    )
 
    return caso_consenso, avg_dist, vecinos
 
 
def obtener_descripcion_antena(l_slot):
    return f"Antena de ranura adaptable (L = {l_slot} mm)"
 
 
def clasificar_caso(musculo, grasa):
    if grasa >= 10:
        return "Paciente con grasa elevada"
    elif musculo >= 35:
        return "Tumor profundo"
    elif musculo <= 15:
        return "Tumor superficial"
    else:
        return "Caso estándar"
 
 
def determinar_seguridad_termica(temp_max):
    if temp_max < 41.5:
        return "🟡 Posible infracaloración"
    elif temp_max <= 44.5:
        return "🟢 Óptima (41.5–44.5 °C)"
    else:
        return "🔴 Riesgo térmico alto"
 
 
def estimar_confianza(dist_media):
    if dist_media <= 2.0:
        return "Alta"
    elif dist_media <= 5.0:
        return "Media"
    else:
        return "Baja"
 
 
