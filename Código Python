    def leer_float(self, widget, name):
        try:
            texto_limpio = widget.get().replace(',', '.').strip()
            return float(texto_limpio)
        except Exception:
            raise ValueError(f"Valor numérico inválido en: {name}.")
 
    # --- LÓGICA DE CÁLCULO ---
    def iniciar_calculo(self):
        try:
            self.cur_nombre = self.ent_nombre.get().strip()
            self.cur_dni = self.ent_dni.get().strip()
            self.cur_edad = self.ent_edad.get().strip()
            self.cur_sexo = self.cmb_sexo.get()
            self.cur_k = int(self.cmb_k.get())
 
            if not validar_dni_nie(self.cur_dni):
                raise ValueError(
                    f"El DNI o NIE introducido ('{self.cur_dni}') no es válido matemáticamente.\n"
                    f"Revise los dígitos y la letra de control."
                )
 
            self.cur_mus = self.leer_float(self.ent_mus, "Músculo")
            self.cur_gra = self.leer_float(self.ent_gra, "Grasa")
 
            # Nueva función 5: coherencia de entrada
            validar_entrada_clinica(
                self.cur_nombre,
                self.cur_dni,
                self.cur_edad,
                self.cur_mus,
                self.cur_gra
            )
 
            self.btn_plan.config(state="disabled")
            self.progreso.pack(fill="x")
            self.lbl_estado.pack()
            self.progreso['value'] = 0
            self.lbl_estado.config(text=f"Consultando base de datos unificada (k={self.cur_k})...")
            self.root.after(400, self.step2)
 
        except ValueError as e:
            messagebox.showerror("Error de Entrada", str(e))
 
    def step2(self):
        self.progreso['value'] = 40
        self.lbl_estado.config(text="Modelando termodinámica de tejidos...")
        self.root.after(500, self.step3)
 
    def step3(self):
        self.progreso['value'] = 80
        self.lbl_estado.config(text="Generando informe físico...")
        self.root.after(400, self.finalizar_calculo)
 
    def finalizar_calculo(self):
        self.progreso['value'] = 100
        self.lbl_estado.config(text="Planificación completada.")
 
        self.root.after(1000, lambda: self.progreso.pack_forget())
        self.root.after(1000, lambda: self.lbl_estado.pack_forget())
        self.btn_plan.config(state="normal")
 
        caso, dist, vecinos = motor_inferencia(self.cur_mus, self.cur_gra, self.cur_k)
        sim = max(0, 100 - dist * 8)
 
        tipo_c = clasificar_caso(self.cur_mus, self.cur_gra)
        confianza = estimar_confianza(dist)
        seg = determinar_seguridad_termica(caso[4])
 
        # Nueva función 2: extrapolación / rango
        rango_cubierto, aviso_rango = evaluar_rango_experiencia(self.cur_mus, self.cur_gra)
 
        # Nueva función 10: simulación futura recomendada
        simulacion_pendiente = determinar_simulacion_pendiente(rango_cubierto, confianza)
 
        if confianza == "Baja":
            seg += " | Confianza reducida por baja similitud anatómica"
 
        self.lbl_tipo.config(text=f"Tipo de caso: {tipo_c}")
        self.lbl_config_antena.config(text=f"Configuración de antena: ranura ajustada a {caso[2]} mm")
        self.lbl_pot.config(text=f"Potencia sugerida: {caso[3]} W")
        self.lbl_temp.config(text=f"Temperatura máxima prevista: {caso[4]} °C")
        self.lbl_sim.config(text=f"Similitud promedio: {sim:.1f}%")
        self.lbl_conf.config(text=f"Confianza de la predicción: {confianza}")
        self.lbl_rango.config(text=f"Rango cubierto por la base: {rango_cubierto}")
        self.lbl_seg.config(text=f"Seguridad térmica: {seg}")
        self.lbl_futuro.config(text=f"Simulación futura recomendada: {simulacion_pendiente}")
 
        if aviso_rango:
            messagebox.showwarning("Aviso de extrapolación", aviso_rango)
 
        self.dibujar_antena(caso[2])
        self.dibujar_mapa_termico(self.cur_gra, self.cur_mus, caso[4])
 
        conn = sqlite3.connect(DB_NAME)
        cursor = conn.cursor()
        fecha_str = datetime.now().strftime("%d/%m/%Y %H:%M")
 
        cursor.execute("""
INSERT INTO Historial_v6 (
fecha, nombre, dni, edad, sexo, musculo, grasa, k_usado,
tipo_caso, l_slot, potencia, temp_max, dist_knn, similitud,
seguridad, confianza, rango_cubierto, simulacion_pendiente
) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
""", (
            fecha_str,
            self.cur_nombre,
            self.cur_dni,
            self.cur_edad,
            self.cur_sexo,
            self.cur_mus,
            self.cur_gra,
            self.cur_k,
            tipo_c,
            caso[2],
            caso[3],
            caso[4],
            dist,
            sim,
            seg,
            confianza,
            rango_cubierto,
            simulacion_pendiente
        ))
 
        conn.commit()
        conn.close()
 
        self.ultimo_resultado = {
            "nombre": self.cur_nombre,
            "dni": self.cur_dni,
            "edad": self.cur_edad,
            "sexo": self.cur_sexo,
